# API Configuration
# Replace with your actual backend API URL
VITE_API_URL=http://localhost:3001/api

# Environment
VITE_ENV=development

# Mock API Mode
# Set to 'true' to use mock data (no backend required - for development)
# Set to 'false' to use real backend API (for production)
VITE_USE_MOCK_API=true

# ──────────────────────────────────────────────────────────
# Microsoft / Azure AD Authentication (MFA via MSAL)
# ──────────────────────────────────────────────────────────
# Required to enable "Sign in with Microsoft" with MFA.
# Register an App in Azure Active Directory and fill in:
#
#   1. VITE_AZURE_CLIENT_ID  — Application (client) ID from the App Registration
#   2. VITE_AZURE_TENANT_ID  — Directory (tenant) ID (or "common" for multi-tenant)
#   3. VITE_AZURE_REDIRECT_URI — Redirect URI added in App Registration
#      (e.g. http://localhost:5173 for dev)
#
# Leave blank to disable Microsoft login.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# IMPORTANT: Never commit the actual .env file to version control
# Copy this file to .env and update with your actual values
